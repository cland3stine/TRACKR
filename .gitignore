# TRACKR test/runtime transient artifacts
tests/.tmp/
.pytest_cache/
tests/.pytest_cache/
*.pyc
__pycache__/

# Pytest fallback temp dirs sometimes created at repo root on Windows
pytest-cache-files-*/

# Non-phase workspace artifacts (not part of TRACKR lock)
.gradle/
build/
dist/
gradle/
assets/
src/
build.gradle
settings.gradle
gradlew
gradlew.bat
SPEC_NOWPLAYINGLITE_CODEX.md

# TRACKR Tauri wrapper build/dependency outputs
ui/trackr-ui/node_modules/
ui/trackr-ui/dist/
ui/trackr-ui/src-tauri/target/
ui/trackr-ui/src-tauri/binaries/

# Claude Code local settings
.claude/

# Local TRACKR runtime outputs/preferences when testing in repo root
TRACKR/
trackr_config.json

# Keep Tauri scaffold source tracked (root has a broad src/ ignore rule)
!ui/trackr-ui/src/
!ui/trackr-ui/src/**
!ui/trackr-ui/src-tauri/src/
!ui/trackr-ui/src-tauri/src/**
