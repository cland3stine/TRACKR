trackr-prolink-test/node_modules/

# Phase 1+ Electron app
trackr-electron/node_modules/
trackr-electron/dist/
trackr-electron/release/

# TRACKR Tauri wrapper build/dependency outputs
ui/trackr-ui/node_modules/
ui/trackr-ui/dist/
ui/trackr-ui/src-tauri/target/
ui/trackr-ui/src-tauri/trackr-backend-*.exe

# Claude Code local settings
.claude/

# Local TRACKR runtime outputs/preferences when testing in repo root
TRACKR/
trackr_config.json

# Keep Tauri scaffold source tracked (root has a broad src/ ignore rule)
!ui/trackr-ui/src/
!ui/trackr-ui/src/**
!ui/trackr-ui/src-tauri/src/
!ui/trackr-ui/src-tauri/src/**

# Keep Electron app source tracked
!trackr-electron/src/
!trackr-electron/src/**

# Keep Electron app assets tracked (icon.ico etc)
!trackr-electron/assets/
!trackr-electron/assets/**

# Keep Electron NSIS installer scripts tracked
!trackr-electron/build/
!trackr-electron/build/**
