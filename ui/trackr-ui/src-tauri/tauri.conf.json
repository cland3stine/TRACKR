{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TRACKR",
  "version": "0.9.0",
  "identifier": "com.clandestine.trackr",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TRACKR",
        "width": 1200,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 900
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:8755 http://localhost:8755; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/trackr-backend"],
    "resources": {
      "../../../build/jpackage/NowPlayingLite-DeviceStartFixed/": "beatlink/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/cland3stine/TRACKR/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE0NTkzRDk0MzI3Mzg0QjYKUldTMmhITXlsRDFacEhRVTAzNnArOXl1Y01Gd3RXQkFiU2ZDem9sZTlWSmNpdFdkRHF1UXczYUwK"
    }
  }
}
